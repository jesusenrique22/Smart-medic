# Flutter app environment (copy to .env)
# Web en tu Mac: localhost/127.0.0.1 está bien.
# Web desde OTRO dispositivo (misma Wi‑Fi): define DEV_HOST = IP del Mac.
API_BASE_URL=http://127.0.0.1:3000
SOCKET_URL=http://127.0.0.1:3001
# IP del Mac en Wi‑Fi (solo modo LAN; no usar con Dev Tunnels)
# DEV_HOST=192.168.1.42
# Puerto del front Flutter web en LAN (./scripts/run-web-lan.sh)
FLUTTER_WEB_PORT=8088
# Panel debug en web por túnel (serve-web-tunnel.sh también usa --dart-define)
ENABLE_DEV_TOOLS=true
# Dev Tunnels (Cursor): URLs HTTPS públicas de los túneles 3000 y 3001 — ver docs/DEV_TUNNELS.md
# PUBLIC_API_URL=https://xxxx-3000.use2.devtunnels.ms
# PUBLIC_SOCKET_URL=https://xxxx-3001.use2.devtunnels.ms
MONGODB_URI=mongodb://localhost:27017/smartmedic

# WebRTC TURN (opcional; sin esto solo hay STUN — puede fallar el audio entre redes distintas)
# WEBRTC_TURN_URL=turn:your-turn.example.com:3478
# WEBRTC_TURN_USERNAME=user
# WEBRTC_TURN_CREDENTIAL=secret

# Probar desde otro dispositivo:
# - Misma Wi‑Fi → docs/DEV_LAN.md (DEV_HOST + http://IP:8080)
# - Dev Tunnels Cursor → docs/DEV_TUNNELS.md (PUBLIC_* + https://...-8080.devtunnels.ms)
# Comprobar puertos: ./scripts/check-dev-ports.sh
