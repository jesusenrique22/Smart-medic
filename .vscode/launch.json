{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter Web (LAN · puerto 8080)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "-d",
        "web-server",
        "--web-hostname",
        "0.0.0.0",
        "--web-port",
        "8080"
      ]
    },
    {
      "name": "Flutter Web (Chrome local)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": ["-d", "chrome"]
    }
  ]
}
