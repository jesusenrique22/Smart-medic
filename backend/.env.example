# MongoDB (local o Atlas)
MONGODB_URI=mongodb://localhost:27017/smartmedic
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/smartmedic?retryWrites=true&w=majority

# API
PORT=3000
JWT_SECRET=cambia-esto-en-produccion

# WebSocket (mismo host/puerto que la API)
# Flutter: SOCKET_URL o API_BASE_URL sin /api

# Zona horaria para horarios de citas (hora de pared → UTC)
APP_TIMEZONE=America/Caracas
APP_TZ_OFFSET_MINUTES=-240
